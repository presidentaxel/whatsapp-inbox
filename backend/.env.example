###########################################
#      Backend environment variables      #
###########################################

# ─── Environnement ─────────────────────────────────────────────────────────
# "development" | "production" | "test"
APP_ENV=development

# ─── Supabase (obligatoire) ─────────────────────────────────────────────────
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_KEY=<service_role_key>
DATABASE_URL=postgresql://user:password@host:5432/postgres
# Optionnel : tailles du pool asyncpg (mode session Supabase ~15 clients max au total).
# PG_POOL_MIN_SIZE=1
# PG_POOL_MAX_SIZE=5

# ─── WhatsApp Cloud API (obligatoire) ───────────────────────────────────────
WHATSAPP_TOKEN=<long-lived-token>
WHATSAPP_PHONE_ID=<phone_number_id>
WHATSAPP_VERIFY_TOKEN=<verify-token>
WHATSAPP_PHONE_NUMBER=+33...

# ─── Meta App (obligatoire pour vérifier la signature des webhooks) ────────
META_APP_ID=<app_id>
META_APP_SECRET=<app_secret>

# ─── Gemini ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TRANSCRIPTION_MODEL=gemini-2.5-flash
AXELIA_FAST_MODEL=gemini-2.5-flash
AXELIA_PRO_MODEL=gemini-2.5-pro

# ─── Escalade humain (facultatif) ──────────────────────────────────────────
HUMAN_BACKUP_NUMBER=

# ─── Monitoring Prometheus ─────────────────────────────────────────────────
PROMETHEUS_ENABLED=true
PROMETHEUS_METRICS_PATH=/metrics
PROMETHEUS_APP_LABEL=whatsapp_inbox_api
# Si défini, /metrics exige `Authorization: Bearer <token>`.
# METRICS_AUTH_TOKEN=

# ─── Multicompte ───────────────────────────────────────────────────────────
DEFAULT_ACCOUNT_SLUG=default-env-account

FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# ─── Google Drive OAuth2 (facultatif) ──────────────────────────────────────
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:5173/api/auth/google-drive/callback


# ─── CORS ──────────────────────────────────────────────────────────────────
# Deux listes distinctes : APP_ENV choisit la bonne. `CORS_ORIGINS` reste un
# override universel (priorité maximale, rétrocompat).
CORS_ORIGINS_DEV=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173
CORS_ORIGINS_PROD=https://app.exemple.com
# CORS_ORIGINS=

# ─── Sécurité webhook Meta ─────────────────────────────────────────────────
# Vérifie X-Hub-Signature-256 avec META_APP_SECRET. À ne désactiver QUE pour
# tester en local avec des payloads non signés.
WEBHOOK_SIGNATURE_REQUIRED=true
# Active POST /webhook/whatsapp/debug (refusé si APP_ENV=production).
WEBHOOK_DEBUG_ENABLED=false

# ─── Rate limiting (slowapi) ───────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_AUTH=20/minute
RATE_LIMIT_WEBHOOK=600/minute
RATE_LIMIT_AI=30/minute

# ─── Edge Function `whatsapp-webhook` (Dashboard → Edge Functions → Secrets) ─
# Sur la plateforme, les variables SUPABASE_* (URL, service role, etc.) sont
# injectées automatiquement : ne pas les définir avec `supabase secrets set`
# (le CLI les refuse : "Env name cannot start with SUPABASE_").
# À définir toi-même, par ex. :
#   npx supabase secrets set META_APP_SECRET=... WHATSAPP_VERIFY_TOKEN=...
# Optionnel :
#   npx supabase secrets set WEBHOOK_SIGNATURE_REQUIRED=false
