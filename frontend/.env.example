    ##########################################
    #     Frontend environment variables     #
    ##########################################

# Toute variable préfixée VITE_ est exposée au navigateur : ne pas y mettre de secrets serveur.

# Projet Supabase (URL + clé anon - la clé service_role reste côté backend uniquement)
VITE_SUPABASE_URL=https://<project>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon_public_key>

# URL du backend API (production / preview). En dev, le proxy Vite /api est utilisé par défaut.
# VITE_BACKEND_URL=https://api.example.com

# false pour appeler le backend directement (VITE_BACKEND_URL) même en dev
# VITE_DEV_PROXY=false

# Cible du proxy dev (/api -> backend). Défaut : http://localhost:8000
# VITE_DEV_BACKEND_URL=http://localhost:8000

# Repo GitHub pour l'écran « Mises à jour » mobile (format owner/repo)
# VITE_GITHUB_REPO=org/whatsapp-inbox
# TEMPLATE_HEADER_STRATEGY=empty_header