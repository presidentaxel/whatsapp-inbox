{
    "name": "whatsapp-inbox-frontend",
    "version": "1.0.0",
    "private": true,
    "engines": {
        "node": ">=20.0.0"
    },
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "build:ci": "cross-env VITE_SUPABASE_URL=https://mock.supabase.co VITE_SUPABASE_ANON_KEY=mock_anon_key_for_ci vite build",
        "preview": "vite preview",
        "version:update": "node scripts/update-version.js",
        "lint": "eslint . --max-warnings=50",
        "lint:ci": "cross-env VITE_SUPABASE_URL=https://mock.supabase.co VITE_SUPABASE_ANON_KEY=mock_anon_key_for_ci eslint . --max-warnings=50",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,md,json}\"",
        "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,css,md,json}\"",
        "test": "vitest run",
        "test:ci": "cross-env VITE_SUPABASE_URL=https://mock.supabase.co VITE_SUPABASE_ANON_KEY=mock_anon_key_for_ci vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@supabase/supabase-js": "^2.45.0",
        "@xyflow/react": "^12.10.2",
        "axios": "^1.15.0",
        "emoji-picker-react": "^4.15.2",
        "pdfjs-dist": "^5.4.530",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-icons": "^4.12.0",
        "react-router-dom": "^6.30.3"
    },
    "devDependencies": {
        "@eslint/js": "^9.18.0",
        "@vitejs/plugin-react": "^4.7.0",
        "@vitest/coverage-v8": "^2.1.8",
        "baseline-browser-mapping": "^2.9.15",
        "cross-env": "^7.0.3",
        "eslint": "^9.18.0",
        "eslint-plugin-react": "^7.37.4",
        "eslint-plugin-react-hooks": "^5.1.0",
        "eslint-plugin-react-refresh": "^0.4.16",
        "globals": "^15.14.0",
        "jsdom": "^25.0.1",
        "prettier": "^3.4.2",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.1",
        "vite": "^6.4.2",
        "vitest": "^2.1.8"
    },
    "overrides": {
        "rollup": "^4.59.0"
    }
}
